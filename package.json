    "pw:ws-recovery-harsh": "PLAYWRIGHT_SCENARIO=ws_recovery PLAYWRIGHT_ALLOW_WS_CRASH=true PLAYWRIGHT_WS_RESTART_DELAY_MS=2500 PLAYWRIGHT_WS_RECOVERY_POST_STRESS_ROUNDS=3 PLAYWRIGHT_WS_RECOVERY_EXTRA_RELOAD=true PLAYWRIGHT_WS_RECOVERY_VERIFY_STABILITY=true PLAYWRIGHT_WS_DROP_YJS_UPDATES=60 PLAYWRIGHT_WS_RECEIVE_DELAY_MS=100 node scripts/playwright-local-group-smoke.mjs",

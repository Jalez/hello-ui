# ============================================
# Authentication (NextAuth)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
# Generate with: openssl rand -base64 32
# Optional safety guard for LTI launches:
# true = reject launches that do not provide a strong unique user identifier
# (e.g. lis_person_sourcedid/custom_user_id).
LTI_REQUIRE_STRONG_IDENTITY=false
# Optional overrides per endpoint:
# - /api/lti/launch (A+ menu item style launch)
LTI_REQUIRE_STRONG_IDENTITY_LAUNCH=false
# - /api/lti/play/[token] (embedded exercise/game launch)
LTI_REQUIRE_STRONG_IDENTITY_PLAY=false

# When enabled, /api/lti/play identities are scoped by a per-browser cookie.
# This prevents two browsers from being forced into the same user when LMS sends
# identical LTI user data for group submissions.
LTI_PLAY_BROWSER_SCOPED_IDENTITY=false

# Advanced: include lis_result_sourcedid in group scope derivation.
# Keep false unless your LMS provides a group-shared sourcedid.
LTI_GROUP_SCOPE_USE_SOURCEDID=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (optional)
GITHUB_ID=your-github-id
GITHUB_SECRET=your-github-secret

# ============================================
# Database
# ============================================
# Option 1: SQLite (current)
DATABASE_URL=file:./db/ui_designer_dev.sqlite

# Option 2: PostgreSQL (Docker Compose uses database name ui_designer — match POSTGRES_DB in docker-compose.yml)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ui_designer

# ============================================
# Stripe (Payment Processing)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Test mode keys start with sk_test_ and pk_test_

# ============================================
# AI Providers
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Other AI Providers
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-key
XAI_API_KEY=your-xai-key
MISTRAL_API_KEY=your-mistral-key

# ============================================
# Google Cloud (for Document AI / OCR - Optional)
# ============================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_KEY_FILE=./service-account-key.json

# ============================================
# File Storage (Optional)
# ============================================
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# ============================================
# Redis / Drawboard Artifact Cache
# ============================================
# Preferred for true local Redis testing:
# REDIS_URL=redis://localhost:6379
#
# Optional alias:
# DRAWBOARD_REDIS_URL=redis://localhost:6379
#
# REST-style fallback for Upstash / hosted Redis REST proxies:
# UPSTASH_REDIS_REST_URL=https://your-upstash-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# REDIS_REST_URL=https://your-redis-rest-endpoint
# REDIS_REST_TOKEN=your-redis-rest-token

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DRAWBOARD_URL=http://localhost:3500
# Optional build-time fallbacks only. Primary settings: Creator → Game → Game settings (drawboard capture mode, manual capture, remote sync debounce).
# browser / playwright — used only when a loaded game has no stored value (defaults in DB are browser / 500ms / manual off).
# NEXT_PUBLIC_DRAWBOARD_CAPTURE_MODE=browser
# NEXT_PUBLIC_REMOTE_SYNC_DEBOUNCE_MS=500
# true/1 = manual capture fallback when game has no stored value. Leave empty for default automatic capture.
# NEXT_PUBLIC_MANUAL_DRAWBOARD_CAPTURE=
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3100
WS_SERVICE_TOKEN=ws-service-secret
NEXT_PUBLIC_COLLAB_ENGINE=yjs
COLLAB_ENGINE=yjs

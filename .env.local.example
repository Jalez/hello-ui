# ============================================
# Authentication (NextAuth)
# ============================================
# Must be the NextAuth API root so callback URL becomes .../api/auth/callback/google
NEXTAUTH_URL=http://localhost:3000/api/auth
NEXTAUTH_SECRET=your-nextauth-secret-here
# Generate with: openssl rand -base64 32
# Google OAuth (for NextAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LTI Identity (for LMS integration)
LTI_REQUIRE_STRONG_IDENTITY=true
LTI_REQUIRE_STRONG_IDENTITY_LAUNCH=false
LTI_REQUIRE_STRONG_IDENTITY_PLAY=true
LTI_PLAY_BROWSER_SCOPED_IDENTITY=false
# Advanced: include lis_result_sourcedid in group scope derivation.
# Keep false unless your LMS provides a group-shared sourcedid.
LTI_GROUP_SCOPE_USE_SOURCEDID=false


# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hello_ui
DB_CLIENT=postgres


# ============================================
# Redis / Drawboard Artifact Cache
# ============================================
# Set ONE mode:
# 1) Native Redis (preferred when app can reach Redis directly):
REDIS_URL=redis://localhost:6379
DRAWBOARD_REDIS_URL=redis://localhost:6379
# 2) REST Redis (for Upstash or hosted REST proxies):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_REST_URL=
REDIS_REST_TOKEN=
# If all values above are empty, cache falls back to in-memory only.

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
# Optional server-side canonical app root for redirects behind proxies.
# If set, server routes prefer this over NEXT_PUBLIC_APP_URL.
APP_ROOT_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH= # Optional base path if app isn't hosted at root of domain, e.g. "/hello-ui"
NEXT_PUBLIC_DRAWBOARD_URL=http://localhost:3500
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3100
WS_SERVICE_TOKEN=ws-service-secret
NEXT_PUBLIC_COLLAB_ENGINE=yjs
COLLAB_ENGINE=yjs



# ============================================
# Support Contact Info (Incase of issues, users can reach out to this email/name)
# ============================================
NEXT_PUBLIC_SUPPORT_EMAIL=jaakko.rajala@tuni.fi
NEXT_PUBLIC_SUPPORT_CONTACT_NAME=Jaakko Rajala

# ============================================
# Developer Testing (Optional)
# ============================================
TEST_OPENROUTER_API_KEY=
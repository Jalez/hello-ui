{
  "restartable": "rs",
  "ignore": [
    ".git",
    "Dockerfile",
    ".dockerignore",
    "db/**/*.json",
    "static_files/**/*.json",
    "node_modules/*",
    "public/*",
    "scripts/*",
    "test/*",
    "views/*"
  ],
  "watch": [
    "*.js",
    "*.json"
  ],
  "verbose": true,
  "env": {
    "NODE_ENV": "development",
    "DEBUG": "ui_designer:*"
  },
  "ext": "js,json",
  "delay": 2500
}
